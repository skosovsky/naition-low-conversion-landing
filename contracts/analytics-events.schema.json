{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naition.local/schemas/analytics-events.schema.json",
  "title": "Landing analytics event contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "experimentId",
    "allowedProperties",
    "events"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "experimentId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "allowedProperties": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "not": {
        "contains": {
          "enum": [
            "name",
            "email",
            "phone",
            "form_data",
            "error_message"
          ]
        }
      }
    },
    "events": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "requiredProperties",
        "providers"
      ],
      "properties": {
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "requiredProperties": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "providers": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ga4",
            "yandex",
            "amplitude"
          ],
          "properties": {
            "ga4": {
              "type": "string",
              "minLength": 1
            },
            "yandex": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            },
            "amplitude": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
