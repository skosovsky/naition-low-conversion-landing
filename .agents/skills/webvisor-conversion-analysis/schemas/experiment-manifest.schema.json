{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naition.local/schemas/conversion-experiment-manifest.schema.json",
  "title": "Conversion experiment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "iterationId",
    "status",
    "comparisonType",
    "hypothesis",
    "baseline",
    "candidate",
    "simulator",
    "cohort",
    "analytics",
    "skill",
    "comparison",
    "decision"
  ],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "iterationId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
    "status": {"const": "completed"},
    "comparisonType": {"enum": ["before_after", "randomized_ab"]},
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "changeSet", "expectedMetric"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1},
        "changeSet": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "expectedMetric": {"type": "string", "minLength": 1}
      }
    },
    "baseline": {"$ref": "#/$defs/revision"},
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitSha", "metric", "deploy"],
      "properties": {
        "commitSha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
        "metric": {"$ref": "#/$defs/metric"},
        "deploy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidenceId",
            "remoteSha",
            "versionMarker",
            "panelResponseSha256",
            "deployedAt",
            "status"
          ],
          "properties": {
            "evidenceId": {"type": "string", "minLength": 1},
            "remoteSha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
            "versionMarker": {"type": "string", "minLength": 1},
            "panelResponseSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "deployedAt": {"type": "string", "format": "date-time"},
            "status": {"const": "succeeded"}
          }
        }
      }
    },
    "simulator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceId",
        "panelResponseSha256",
        "requestedVisits",
        "observedVisits",
        "startedAt",
        "endedAt"
      ],
      "properties": {
        "evidenceId": {"type": "string", "minLength": 1},
        "panelResponseSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "requestedVisits": {"const": 100},
        "observedVisits": {"const": 100},
        "startedAt": {"type": "string", "format": "date-time"},
        "endedAt": {"type": "string", "format": "date-time"}
      }
    },
    "cohort": {"$ref": "#/$defs/window"},
    "analytics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server", "yandex", "ga4", "amplitude", "leaderboard"],
      "properties": {
        "server": {"$ref": "#/$defs/source"},
        "yandex": {"$ref": "#/$defs/source"},
        "ga4": {"$ref": "#/$defs/source"},
        "amplitude": {"$ref": "#/$defs/source"},
        "leaderboard": {"$ref": "#/$defs/source"}
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "versionHash"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "versionHash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baselineCr", "candidateCr", "deltaPp", "relativeLiftPct"],
      "properties": {
        "baselineCr": {"type": "number", "minimum": 0, "maximum": 100},
        "candidateCr": {"type": "number", "minimum": 0, "maximum": 100},
        "deltaPp": {"type": "number"},
        "relativeLiftPct": {"type": ["number", "null"]}
      }
    },
    "decision": {"enum": ["promote", "revert", "inconclusive"]}
  },
  "$defs": {
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "numerator", "denominator", "cr"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "numerator": {"type": "integer", "minimum": 0},
        "denominator": {"type": "integer", "minimum": 1},
        "cr": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitSha", "metric"],
      "properties": {
        "commitSha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
        "metric": {"$ref": "#/$defs/metric"},
        "deploy": {"type": "object"}
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "goal", "collectedAt", "window", "metric", "artifact"],
      "properties": {
        "status": {"const": "ok"},
        "goal": {"type": "string", "minLength": 1},
        "collectedAt": {"type": "string", "format": "date-time"},
        "window": {"$ref": "#/$defs/window"},
        "metric": {"$ref": "#/$defs/metric"},
        "artifact": {"type": "string", "pattern": "^sources/[a-z0-9._-]+\\.json$"}
      }
    }
  }
}
