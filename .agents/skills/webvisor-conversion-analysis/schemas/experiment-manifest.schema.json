{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naition.local/schemas/conversion-experiment-manifest.schema.json",
  "title": "Conversion experiment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "iterationId",
    "status",
    "comparisonType",
    "hypothesis",
    "baseline",
    "candidate",
    "simulator",
    "cohort",
    "analytics",
    "skill",
    "comparison",
    "discrepancies",
    "processDeviations",
    "decision"
  ],
  "properties": {
    "schemaVersion": {"const": "2.0.0"},
    "iterationId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
    "status": {"const": "completed"},
    "comparisonType": {"enum": ["before_after", "randomized_ab"]},
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "changeSet", "expectedMetric"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1},
        "changeSet": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "expectedMetric": {"type": "string", "minLength": 1}
      }
    },
    "baseline": {"$ref": "#/$defs/revision"},
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitSha", "metric", "deploy"],
      "properties": {
        "commitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "metric": {"$ref": "#/$defs/metric"},
        "deploy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidenceId",
            "remoteSha",
            "versionMarker",
            "panelResponseSha256",
            "deployedAt",
            "status"
          ],
          "properties": {
            "evidenceId": {"type": "string", "minLength": 1},
            "remoteSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
            "versionMarker": {"type": "string", "minLength": 1},
            "panelResponseSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "deployedAt": {"type": "string", "format": "date-time"},
            "status": {"const": "succeeded"}
          }
        }
      }
    },
    "simulator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceId",
        "panelResponseSha256",
        "requestedVisits",
        "successfulVisits",
        "failedVisits",
        "attempts",
        "startedAt",
        "endedAt"
      ],
      "properties": {
        "evidenceId": {"type": "string", "minLength": 1},
        "panelResponseSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "requestedVisits": {"const": 100},
        "successfulVisits": {"const": 100},
        "failedVisits": {"const": 0},
        "attempts": {"const": 1},
        "startedAt": {"type": "string", "format": "date-time"},
        "endedAt": {"type": "string", "format": "date-time"}
      }
    },
    "cohort": {"$ref": "#/$defs/window"},
    "analytics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server", "yandex", "ga4", "amplitude", "leaderboard"],
      "properties": {
        "server": {"$ref": "#/$defs/source"},
        "yandex": {"$ref": "#/$defs/source"},
        "ga4": {"$ref": "#/$defs/source"},
        "amplitude": {"$ref": "#/$defs/source"},
        "leaderboard": {"$ref": "#/$defs/source"}
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "versionHash", "previousVersionHash"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "versionHash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "previousVersionHash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baselineCr",
        "candidateCr",
        "deltaPp",
        "relativeLiftPct",
        "differenceCi95Pp",
        "fisherExactTwoSidedP"
      ],
      "properties": {
        "baselineCr": {"type": "number", "minimum": 0, "maximum": 100},
        "candidateCr": {"type": "number", "minimum": 0, "maximum": 100},
        "deltaPp": {"type": "number"},
        "relativeLiftPct": {"type": ["number", "null"]},
        "differenceCi95Pp": {
          "type": "array",
          "prefixItems": [{"type": "number"}, {"type": "number"}],
          "minItems": 2,
          "maxItems": 2
        },
        "fisherExactTwoSidedP": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "discrepancies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "processDeviations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "decision": {"enum": ["promote", "revert", "inconclusive"]}
  },
  "$defs": {
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "numerator", "denominator", "denominatorSemantics", "cr"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "numerator": {"type": "integer", "minimum": 0},
        "denominator": {"type": "integer", "minimum": 1},
        "denominatorSemantics": {"type": "string", "minLength": 1},
        "cr": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitSha", "metric"],
      "properties": {
        "commitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "metric": {"$ref": "#/$defs/metric"}
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "goal",
            "collectedAt",
            "window",
            "freshness",
            "sampling",
            "metric",
            "artifact"
          ],
          "properties": {
            "status": {"const": "available"},
            "goal": {"type": "string", "minLength": 1},
            "collectedAt": {"type": "string", "format": "date-time"},
            "window": {"$ref": "#/$defs/window"},
            "freshness": {"type": "string", "minLength": 1},
            "sampling": {"type": "string", "minLength": 1},
            "metric": {"$ref": "#/$defs/metric"},
            "artifact": {
              "type": "string",
              "pattern": "^normalized/[a-z0-9._-]+\\.json$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "goal",
            "collectedAt",
            "requestedWindow",
            "blocker",
            "artifact"
          ],
          "properties": {
            "status": {"enum": ["unavailable", "stale"]},
            "goal": {"type": "string", "minLength": 1},
            "collectedAt": {"type": "string", "format": "date-time"},
            "requestedWindow": {"$ref": "#/$defs/window"},
            "blocker": {"type": "string", "minLength": 1},
            "artifact": {
              "type": "string",
              "pattern": "^normalized/[a-z0-9._-]+\\.json$"
            }
          }
        }
      ]
    }
  }
}
